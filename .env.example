# Sanity — get project ID from sanity.io after provisioning
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2026-05-01
SANITY_API_READ_TOKEN=          # viewer token; server contexts only
SANITY_API_WRITE_TOKEN=         # editor token; server action writes function enquiries
SANITY_REVALIDATE_SECRET=       # POST /api/revalidate webhook secret

# Site
NEXT_PUBLIC_SITE_URL=https://beercade.com.au

# Resend — https://resend.com/api-keys
RESEND_API_KEY=
RESEND_FROM_FUNCTIONS=functions@beercade.com.au   # customer-facing sender
RESEND_FROM_HELLO=hello@beercade.com.au           # internal-notification sender
RESEND_REPLY_TO=functions@beercade.com.au         # replies thread back to group inbox
TEAM_INBOX=functions@beercade.com.au              # Google Group: all team members

# Google Calendar — keyless via Workload Identity Federation (Vercel OIDC).
# org policy iam.disableServiceAccountKeyCreation blocks downloaded SA keys.
# Setup + where to find each value: https://vercel.com/docs/oidc/gcp
# VERCEL_OIDC_TOKEN is injected automatically on Vercel (locally: `vercel env pull`).
GCP_PROJECT_ID=                              # IAM & Admin -> Settings
GCP_PROJECT_NUMBER=                          # IAM & Admin -> Settings
GCP_SERVICE_ACCOUNT_EMAIL=                   # the keyless SA shared into the calendar
GCP_WORKLOAD_IDENTITY_POOL_ID=               # e.g. vercel
GCP_WORKLOAD_IDENTITY_POOL_PROVIDER_ID=      # e.g. vercel
GOOGLE_BOOKINGS_CALENDAR_ID=c_eca3a9296250d410b444fd51b6f76547422c24b2a4b792498ef37db5f343d888@group.calendar.google.com   # Beercade Bookings (non-secret; created 31 May 2026)

# Cloudflare Turnstile — https://dash.cloudflare.com
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Upstash Redis — https://console.upstash.com
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Kit (ConvertKit V4 API) — https://app.kit.com/account_settings/developer_settings
KIT_API_KEY=
KIT_FORM_ID_FOOTER=
KIT_FORM_ID_POPUP=
KIT_TAG_REGULAR=
KIT_TAG_FUNCTION_ENQUIRER=
KIT_TAG_DATE_NIGHT=
KIT_TAG_PINBALL=

# Sentry — https://sentry.io
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# Plausible Cloud
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=beercade.com.au
NEXT_PUBLIC_PLAUSIBLE_HOST=https://plausible.io
